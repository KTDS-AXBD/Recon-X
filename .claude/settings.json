{
  "permissions": {
    "allow": [
      "Bash(bun *)",
      "Bash(bun run *)",
      "Bash(bunx *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git add *)",
      "Bash(gh *)",
      "Bash(ls *)",
      "Bash(wrangler *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun run typecheck 2>&1 | tail -20; bun run lint 2>&1 | tail -20"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -qE '\\.dev\\.vars|\\.env'; then echo 'BLOCKED: 민감 파일(.dev.vars/.env) 편집이 차단되었습니다'; exit 2; fi"
          }
        ]
      }
    ]
  }
}
